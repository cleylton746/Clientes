function inserirLinhaFila(cnpj, box) {
    const item = document.createElement('div');
    item.className = 'queue-item';
    item.innerHTML = `<span>${formatarCnpjTexto(cnpj)}</span><button class="btn-copy-item" onclick="clicarItemFila('${cnpj}')">Ver</button>`;
