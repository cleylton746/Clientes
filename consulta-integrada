function normalizarTexto(txt) { return String(txt).toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim(); }

// ========================================================
// MÓDULO DE LEITURA COMPLETAMENTE ULTRA-TOLERANTE
// ========================================================
function processarUploadArquivo(input, alvoMemoria) {
    if (!supabaseClient) {
        alert("Erro: O cliente Supabase não foi carregado corretamente.");
        return;
    }
    const file = input.files[0];
    if(!file) return;
    const prefixo = alvoMemoria === 'smart' ? 'Smart' : 'Contas';
    const statusEl = document.getElementById(`status${prefixo}`);
    const pBar = document.getElementById(`pBar${prefixo}`);
    document.getElementById(`pWrap${prefixo}`).style.display = 'block';
    pBar.style.width = '30%';
    pBar.style.backgroundColor = '#4f46e5';

    statusEl.textContent = "Lendo arquivo excel...";

    const reader = new FileReader();
    reader.onload = async function(e) {
        try {
            const data = new Uint8Array(e.target.result);
            const workbook = XLSX.read(data, {type: 'array', cellDates: true, raw: false});
            const rows = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]], {header: 1, defval: ""});
            
            let headerRowIndex = -1;
            let pacoteDadosSupabase = [];

            if (alvoMemoria === 'smart') {
                let cIdx = -1, dIdx = -1, sIdx = -1;
                
                for (let i = 0; i < Math.min(rows.length, 30); i++) {
                    if (rows[i] && rows[i].length > 0) {
                        let rTxt = rows[i].map(el => normalizarTexto(el));
                        cIdx = rTxt.findIndex(txt => txt === 'CNPJ' || txt.includes('CNPJ') || txt.includes('DOCUMENTO') || txt.includes('CPF'));
                        dIdx = rTxt.findIndex(txt => txt.includes('DATA') || txt.includes('ATIVACAO'));
                        sIdx = rTxt.findIndex(txt => txt.includes('STATUS') || txt.includes('BASE') || txt.includes('FRESH'));
                        if (cIdx !== -1) { headerRowIndex = i; break; }
                    }
                }
                
                if (cIdx === -1) {
                    // Fallback se não encontrar nomes explícitos: assume colunas 0, 1 e 2 caso tenham dados
                    headerRowIndex = rows.findIndex(r => r && r.length >= 2 && String(r[0]).replace(/\D/g,'').length >= 11);
                    if (headerRowIndex !== -1) {
                        cIdx = 0; dIdx = 1; sIdx = 2;
                    } else {
                        throw new Error('Não encontramos a coluna de CNPJ na planilha Smart.');
                    }
                }
                
                statusEl.textContent = "Extraindo dados do Smart...";
                pBar.style.width = '60%';

                for (let i = headerRowIndex + 1; i < rows.length; i++) {
                    const r = rows[i]; 
                    if (!r || r[cIdx] === undefined || r[cIdx] === null || String(r[cIdx]).trim() === "") continue;
                    
                    let cLimpo = normalizarChaveCnpj(r[cIdx]); 
                    if (!cLimpo || cLimpo.trim() === "") continue;
                    
                    let dVal = dIdx !== -1 ? r[dIdx] : '';
                    let dStr = "Não Informada";

                    if (dVal instanceof Date && !isNaN(dVal.getTime())) {
                        dStr = dVal.toLocaleDateString('pt-BR');
                    } else if (typeof dVal === 'number' && dVal > 0) {
                        let dateObj = XLSX.SSF.parse_date_code(dVal);
                        if (dateObj) {
                            dStr = `${String(dateObj.d).padStart(2,'0')}/${String(dateObj.m).padStart(2,'0')}/${dateObj.y}`;
                        }
                    } else if (String(dVal).trim() !== "" && String(dVal).toLowerCase() !== "vazio") {
                        dStr = String(dVal).trim();
                    }
                    
                    let sStr = "vazio";
                    if (sIdx !== -1 && r[sIdx] !== undefined && r[sIdx] !== null) {
                        let valorBruto = String(r[sIdx]).toLowerCase().trim();
                        if (valorBruto.includes("base")) sStr = "base";
                        else if (valorBruto.includes("fresh")) sStr = "fresh";
                    }
                    
                    pacoteDadosSupabase.push({
                        cnpj: cLimpo,
                        data_ativacao: dStr,
                        status: sStr.toUpperCase()
                    });
                }

                if (pacoteDadosSupabase.length > 0) {
                    const { error } = await supabaseClient
                        .from('base_smart')
                        .upsert(pacoteDadosSupabase, { onConflict: 'cnpj', ignoreDuplicates: false });
                    if (error) throw error;
                }

            } else {
                let docIdx = -1, perfIdx = -1;
                
                // Varre as primeiras 40 linhas procurando palavras chave estruturadas
                for (let i = 0; i < Math.min(rows.length, 40); i++) {
                    if (rows[i] && rows[i].length > 0) {
                        let rTxt = rows[i].map(el => normalizarTexto(el));
                        docIdx = rTxt.findIndex(txt => txt.includes('DOCUMENTA') || txt.includes('CNPJ') || txt.includes('CPF') || txt.includes('DOCUMENTO') || txt === 'CLIENTE');
                        perfIdx = rTxt.findIndex(txt => txt.includes('PERFIL') || txt.includes('COBRANCA') || txt.includes('COBRANÇA') || txt.includes('FORMA') || txt.includes('STATUS'));
                        
                        if (docIdx !== -1 && perfIdx !== -1) { headerRowIndex = i; break; }
                    }
                }
                
                // SUPER FALLBACK POSITION: Se não achar nomes de cabeçalhos, descobre a primeira linha com um CNPJ/CPF válido
                if (docIdx === -1 || perfIdx === -1) {
                    for (let i = 0; i < rows.length; i++) {
                        if (rows[i] && rows[i].length >= 2) {
                            // Encontra alguma coluna com número longo limpando caracteres
                            let col0_limpa = String(rows[i][0]).replace(/\D/g, '');
                            let col1_limpa = String(rows[i][1]).replace(/\D/g, '');
                            
                            if (col0_limpa.length >= 11 && col0_limpa.length <= 15) {
                                docIdx = 0; perfIdx = 1; headerRowIndex = i - 1; break;
                            } else if (col1_limpa.length >= 11 && col1_limpa.length <= 15) {
                                docIdx = 1; perfIdx = 0; headerRowIndex = i - 1; break;
                            }
                        }
                    }
                }

                // Último recurso caso a planilha seja bizarra
                if (docIdx === -1 || perfIdx === -1) {
                    docIdx = 0;
                    perfIdx = 1;
                    headerRowIndex = -1; // Lê a partir da primeira linha
                }
                
                statusEl.textContent = "Sincronizando faturamento de contas...";
                pBar.style.width = '60%';

                for (let i = headerRowIndex + 1; i < rows.length; i++) {
                    const r = rows[i]; 
                    if (!r || r[docIdx] === undefined || r[docIdx] === null || String(r[docIdx]).trim() === "") continue;
                    
                    let cLimpo = normalizarChaveCnpj(r[docIdx]); 
                    if (!cLimpo || cLimpo.trim() === "" || cLimpo.length < 5) continue; // Descarta cabeçalhos residuais literais

                    let perfilTexto = r[perfIdx] !== undefined && r[perfIdx] !== null ? String(r[perfIdx]).trim() : 'vazio';

                    pacoteDadosSupabase.push({
                        documentacaocliente: cLimpo,
                        perfil_cobranca: perfilTexto || 'vazio'
                    });
                }

                if (pacoteDadosSupabase.length > 0) {
                    // Apaga registros anteriores do cliente antes de inserir novos (evita duplicatas entre importações)
                    const docsUnicos = [...new Set(pacoteDadosSupabase.map(r => r.documentacaocliente))];
                    for (let i = 0; i < docsUnicos.length; i += 250) {
                        const lote = docsUnicos.slice(i, i + 250);
                        await supabaseClient.from('base_contas').delete().in('documentacaocliente', lote);
                    }
                    // Insere todos os perfis (inclusive múltiplos por cliente)
                    const tamanhoLote = 250;
                    for (let i = 0; i < pacoteDadosSupabase.length; i += tamanhoLote) {
                        let loteAtual = pacoteDadosSupabase.slice(i, i + tamanhoLote);
                        const { error } = await supabaseClient
                            .from('base_contas')
                            .insert(loteAtual);
                        if (error) console.error("Falha no lote de upload: ", error);
                    }
                }
            }

            pBar.style.width = '100%';
            statusEl.textContent = `✅ ${pacoteDadosSupabase.length.toLocaleString('pt-BR')} registros sincronizados!`;
            
            await carregarDadosDoBancoSupabase();
            setTimeout(() => { document.getElementById(`pWrap${prefixo}`).style.display = 'none'; }, 2000);

        } catch(err) { 
            console.error(err);
            statusEl.textContent = '❌ Falha estrutural no arquivo.'; 
            pBar.style.backgroundColor = '#ef4444';
            alert("Erro durante processamento:\n" + (err.message || JSON.stringify(err)));
        } finally { 
            GarantirFocoInput(); 
        }
    };
    reader.readAsArrayBuffer(file);
}

function exportarBaseDados(tipo) {
    if (tipo === 'smart') {
        const chaves = Object.keys(DB_SMART); if (chaves.length === 0) return;
        let d = [["CNPJ", "DATA DO SERVIÇO MAIS ANTIGO", "BASE/FRESH"]];
        chaves.forEach(k => d.push([k, DB_SMART[k].data_ativacao, DB_SMART[k].status === "vazio" ? "Vazio" : DB_SMART[k].status.toUpperCase()]));
        const ws = XLSX.utils.aoa_to_sheet(d); const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Smart"); XLSX.writeFile(wb, "Base_Smart.xlsx");
    } else {
        const chaves = Object.keys(DB_CONTAS); if (chaves.length === 0) return;
        let d = [["documentacaoCliente", "PERFIL DE COBRANÇA"]];
        chaves.forEach(k => DB_CONTAS[k].forEach(p => d.push([k, p])));
        const ws = XLSX.utils.aoa_to_sheet(d); const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Contas"); XLSX.writeFile(wb, "Base_Contas.xlsx");
    }
    GarantirFocoInput();
}

function formatarCnpjTexto(v) {
    v = v.replace(/\D/g, '');
    if (v.length === 11) return v.replace(/^(\d{3})(\d{3})(\d{3})(\d{2})$/, "$1.$2.$3-$4");
    if (v.length < 14) v = v.padStart(14, '0');
    return v.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, "$1.$2.$3/$4-$5");
}

function formatCNPJ(input) {
    let v = input.value.replace(/\D/g, '');
    if (v.length > 14) v = v.substring(0, 14);
    if (v.length > 12) v = v.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, "$1.$2.$3/$4-$5");
    else if (v.length > 8) v = v.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})$/, "$1.$2.$3/$4");
    else if (v.length > 5) v = v.replace(/^(\d{2})(\d{3})(\d{3})$/, "$1.$2.$3");
    else if (v.length > 2) v = v.replace(/^(\d{2})(\d{3})$/, "$1.$2");
    input.value = v;
}
